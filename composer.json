{
  "name": "underwear/llm-wrapper",
  "description": "A fluent PHP wrapper for LLM APIs with function calling support",
  "type": "library",
  "keywords": [
    "llm",
    "openai",
    "gpt",
    "claude",
    "gemini",
    "antropic",
    "chatgpt",
    "ai",
    "wrapper",
    "api"
  ],
  "homepage": "https://github.com/underwear/llm-wrapper",
  "license": "MIT",
  "authors": [
    {
      "name": "underwear",
      "email": "thisfil@yandex.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "guzzlehttp/guzzle": "^7.5",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Underwear\\LlmWrapper\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Underwear\\LlmWrapper\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "cs-fix": "vendor/bin/php-cs-fixer fix",
    "analyze": "vendor/bin/phpstan analyse"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}